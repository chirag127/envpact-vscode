{
  "name": "envpact",
  "displayName": "envpact",
  "description": "Centralized, serverless secrets manager — manage your private vault visually inside VS Code.",
  "version": "0.4.0",
  "publisher": "chirag127",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "secrets",
    "env",
    "dotenv",
    "envpact",
    "secrets-manager"
  ],
  "homepage": "https://envpact.oriz.in",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chirag127/envpact-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/chirag127/envpact-vscode/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.env.example",
    "onCommand:envpact.generateEnv",
    "onCommand:envpact.initVault",
    "onCommand:envpact.refreshVault"
  ],
  "contributes": {
    "commands": [
      {
        "command": "envpact.generateEnv",
        "title": "envpact: Generate .env"
      },
      {
        "command": "envpact.initVault",
        "title": "envpact: Initialize Vault"
      },
      {
        "command": "envpact.refreshVault",
        "title": "envpact: Refresh Vault"
      },
      {
        "command": "envpact.addSecret",
        "title": "envpact: Add Project Secret"
      },
      {
        "command": "envpact.addSharedSecret",
        "title": "envpact: Add Shared Secret"
      },
      {
        "command": "envpact.rotateSecret",
        "title": "envpact: Rotate Shared Secret"
      },
      {
        "command": "envpact.syncGitHub",
        "title": "envpact: Sync to GitHub Actions"
      },
      {
        "command": "envpact.listProjects",
        "title": "envpact: List Projects"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envpact",
          "title": "envpact",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "envpact": [
        {
          "id": "envpact.projects",
          "name": "Projects"
        },
        {
          "id": "envpact.shared",
          "name": "Shared Secrets"
        }
      ]
    },
    "configuration": {
      "title": "envpact",
      "properties": {
        "envpact.defaultEnvironment": {
          "type": "string",
          "enum": [
            "default",
            "development",
            "staging",
            "production"
          ],
          "default": "default",
          "description": "Default environment used when generating .env files."
        },
        "envpact.autoPullOnGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Auto-pull the vault repo before generating .env."
        },
        "envpact.exampleFile": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative path of the .env.example to use as the spec. Leave empty to scan and prompt."
        },
        "envpact.outputFile": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative path of the target .env file to write. Leave empty to scan and prompt (default: .env, or the convention-paired target for the chosen example)."
        },
        "envpact.writeMode": {
          "type": "string",
          "enum": [
            "ask",
            "merge",
            "overwrite",
            "dry-run"
          ],
          "enumDescriptions": [
            "Ask each run (legacy v0.3.0 behaviour).",
            "Always merge: vault values overlay user-edited values; user-only keys preserved (default).",
            "Always overwrite: vault contents replace the target file; user-only keys are lost.",
            "Always dry-run: print the plan, never touch disk."
          ],
          "default": "merge",
          "description": "How to handle an existing target file when generating .env. v0.4.0 default is 'merge' — never destroys user data. Set to 'ask' to bring back the v0.3.0 prompt."
        },
        "envpact.autoSyncOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Auto-push changes to your vault whenever you save a .env file. Local values overwrite remote on conflict; remote-only keys are preserved; new local keys are promoted to the SHARED namespace."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "envpact.refreshVault",
          "when": "view == envpact.projects",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "node --test --import tsx tests/*.test.ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@11.8.0"
}
